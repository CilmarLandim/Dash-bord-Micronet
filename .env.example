# Servidor
PORT=3001
NODE_ENV=development

# API
VITE_API_URL=http://localhost:3001/api

# Integração com LAN
LAN_SERVER_URL=http://192.168.1.100:8080
LAN_SHARED_FOLDER=/documentos
LAN_USERNAME=admin
LAN_PASSWORD=password

# Impressora
PRINTER_NAME=Impressora Micronet
